generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int           @id @default(autoincrement())
  clerkId  String   @unique
  email      String        @unique
  name       String
  role       Role          @default(PARTICIPANT)
  avatar_url String?
  score      Int           @default(0)
  responses  Response[]
  results    RoundResult[]
}

model AllowedUsers {
  id    Int    @id @default(autoincrement())
  email String @unique
}

model Round {
  id        Int           @id @default(autoincrement())
  status    RoundStatus
  questions Question[]
  responses Response[]
  results   RoundResult[]
  startedAt   DateTime?   
  endsAt      DateTime?   
}

model Question {
  id        Int        @id @default(autoincrement())
  roundId   Int
  text      String
  options   Json?
  answer    String
  link      String?
  reward    Int
  round     Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  responses Response[]

  @@index([roundId])
}

model Response {
  id              Int      @id @default(autoincrement())
  userId          Int
  questionId      Int
  roundId         Int
  submittedAnswer String
  isCorrect       Boolean
  pointsEarned    Int
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  round           Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([roundId])
}

model RoundResult {
  id         Int       @id @default(autoincrement())
  userId     Int
  roundId    Int
  startTime  DateTime
  endTime    DateTime?
  totalTime  Int?
  totalScore Int       @default(0)
  finished   Boolean   @default(false)
  round      Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roundId])
  @@index([roundId])
}

enum Role {
  ORGANIZER
  PARTICIPANT
}

enum RoundStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}
